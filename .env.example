PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-this-with-at-least-32-random-characters
DATABASE_PATH=./apps/api/data/chat.db
UPLOAD_DIR=./apps/api/uploads
MAX_FILE_SIZE_MB=20

# Ustaw w apps/web/.env tylko wtedy, gdy API działa pod innym adresem:
# VITE_API_URL=http://localhost:4000

# Przygotowane pod późniejszą migrację produkcyjną; lokalny adapter ich nie używa.
DATABASE_URL=postgresql://user:password@localhost:5432/halo
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
REDIS_URL=
